# ===== Приложение =====
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== База данных (PostgreSQL) =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mediagen
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=mediagenerator
DATABASE_URL=postgresql://mediagen:change_me_postgres_password@postgres:5432/mediagenerator

# ===== MinIO (S3-совместимое хранилище) =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio_password
S3_BUCKET=mediagenerator
S3_REGION=us-east-1

# ===== Шифрование API ключей =====
# Сгенерировать: openssl rand -hex 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# ===== Better Auth =====
BETTER_AUTH_SECRET=change_me_generate_with_openssl_rand_hex_32
BETTER_AUTH_URL=http://localhost:3000

# ===== Cron (проверка обновлений моделей) =====
# Сгенерировать: openssl rand -hex 16
# Вызов: curl -X POST -H "Authorization: Bearer $CRON_SECRET" http://localhost:3000/api/cron/model-check
CRON_SECRET=change_me_generate_with_openssl_rand_hex_16
